{
  "realm": "pochampally",
  "enabled": true,
  "displayName": "Pochampally Saree Shop",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Shop administrator - can manage sarees, view orders, update order status"
      },
      {
        "name": "CUSTOMER",
        "description": "Customer - can place orders and track them"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@pochampally.com",
      "firstName": "Shop",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "customer1",
      "email": "customer@example.com",
      "firstName": "Priya",
      "lastName": "Sharma",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": false
        }
      ],
      "realmRoles": ["CUSTOMER"]
    }
  ],
  "clients": [
    {
      "clientId": "pochampally-frontend",
      "name": "Pochampally Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "pochampally-backend",
      "name": "Pochampally Backend",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "foo",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
