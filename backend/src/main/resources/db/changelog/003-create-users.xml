<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-users" author="homebase_db">
        <createTable tableName="users" schemaName="homebase_db">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(200)"/>
            <column name="email" type="VARCHAR(200)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="password_hash" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)" defaultValue="CUSTOMER">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_time" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <!-- Seed admin user: email=admin@dhanunjaiah.com, password=admin123 (BCrypt hashed) -->
        <insert tableName="users" schemaName="homebase_db">
            <column name="id" value="admin-001"/>
            <column name="name" value="Dhanunjaiah Admin"/>
            <column name="email" value="admin@dhanunjaiah.com"/>
            <column name="password_hash" value="$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy"/>
            <column name="role" value="ADMIN"/>
        </insert>
    </changeSet>

</databaseChangeLog>
